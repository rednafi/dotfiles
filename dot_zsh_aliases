# -*- mode: shell-script -*-
##########################################
# Aliases
##########################################

unalias ,brclr ,docker-prune-containers ,docker-prune-images \
    ,docker-prune-volumes ,docker-nuke cat python tk jetbox 2>/dev/null

# Git: Clear branches except current, 'main', 'master', 'staging', 'development'.
,brclr() {
    local current branch

    current="$(git branch --show-current 2>/dev/null)" || return
    git branch --format='%(refname:short)' 2>/dev/null |
        while IFS= read -r branch; do
            case "$branch" in
                "$current"|main|master|staging|development) continue ;;
            esac
            git branch -D "$branch"
        done
}

## Unix
alias sudo="sudo "
alias cp="cp -iv"
alias mv="mv -iv"
alias rm="rm -iv"

if ls --color=auto -d . >/dev/null 2>&1; then
    alias ls="ls --color=auto"
else
    alias ls="ls -G"
fi

command -v bat >/dev/null 2>&1 && alias cat="bat"
command -v python3.14 >/dev/null 2>&1 && alias python="python3.14"


# Docker
_docker_available() {
    command -v docker >/dev/null 2>&1
}

,docker-prune-containers() {
    _docker_available || return 0

    local containers
    containers=("${(@f)$(docker ps -aq 2>/dev/null)}")
    (( ${#containers[@]} )) || return 0

    docker stop "${containers[@]}" 2>/dev/null || true
    docker rm "${containers[@]}" 2>/dev/null || true
}

,docker-prune-images() {
    _docker_available || return 0

    local images
    images=("${(@f)$(docker images -q 2>/dev/null)}")
    (( ${#images[@]} )) || return 0

    docker rmi --force "${images[@]}" || true
}

,docker-prune-volumes() {
    _docker_available || return 0
    docker system prune -af --volumes
}

,docker-nuke() {
    ,docker-prune-containers
    ,docker-prune-images
    ,docker-prune-volumes
}


# Doordash / wolt
command -v tsh >/dev/null 2>&1 && alias tk="tsh kubectl"
[[ -x "$HOME/.local/bin/jetbox" ]] && alias jetbox="$HOME/.local/bin/jetbox"

# Misc
alias ,clear-junk='
    echo "Clearing user caches..." &&
    sudo rm -rf /System/Volumes/Data/Users/$USER/Library/Caches/* 2>/dev/null;
    echo "Clearing system caches..." &&
    sudo rm -rf /Library/Caches/* 2>/dev/null;
    echo "Clearing system temp files..." &&
    sudo rm -rf /var/tmp/* 2>/dev/null;
    sudo rm -rf /private/var/folders/*/* 2>/dev/null;
    echo "Clearing system logs..." &&
    sudo rm -rf /private/var/log/asl/*.asl 2>/dev/null;
    sudo rm -rf /Library/Logs/* 2>/dev/null;
    rm -rf ~/Library/Logs/* 2>/dev/null;
    echo "Clearing crash reports..." &&
    rm -rf ~/Library/Logs/DiagnosticReports/* 2>/dev/null;
    sudo rm -rf /Library/Logs/DiagnosticReports/* 2>/dev/null;
    echo "Clearing QuickLook cache..." &&
    qlmanage -r cache 2>/dev/null;
    echo "Emptying Trash..." &&
    sudo rm -rf ~/.Trash/* 2>/dev/null;
    echo "Clearing old iOS backups..." &&
    rm -rf ~/Library/Application\ Support/MobileSync/Backup/* 2>/dev/null;
    echo "Clearing Chrome cache and junk..." &&
    rm -rf ~/Library/Caches/Google/Chrome/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/OptGuideOnDeviceModel 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/optimization_guide_model_store 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/extensions_crx_cache 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/component_crx_cache 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/GoogleUpdater/crx_cache 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/Default/Service\ Worker/CacheStorage/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/Default/GPUCache/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/Crash\ Reports/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Google/Chrome/ShaderCache/* 2>/dev/null;
    echo "Clearing Slack cache..." &&
    rm -rf ~/Library/Caches/com.tinyspeck.slackmacgap/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Slack/Cache/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Slack/Service\ Worker/CacheStorage/* 2>/dev/null;
    echo "Clearing Zoom cache and logs..." &&
    rm -rf ~/Library/Caches/us.zoom.xos/* 2>/dev/null;
    rm -rf ~/Library/Logs/zoom.us/* 2>/dev/null;
    echo "Clearing VS Code cache..." &&
    rm -rf ~/Library/Application\ Support/Code/Cache/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Code/CachedData/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Code/CachedExtensionVSIXs 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Code/CachedExtensions/* 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Code/Service\ Worker 2>/dev/null;
    rm -rf ~/Library/Application\ Support/Code/GPUCache 2>/dev/null;
    echo "Clearing Python caches..." &&
    uv cache clean 2>/dev/null;
    rm -rf ~/.cache/pre-commit 2>/dev/null;
    rm -rf ~/Library/Application\ Support/virtualenv 2>/dev/null;
    command -v pip3 >/dev/null 2>&1 && pip3 cache purge 2>/dev/null;
    echo "Clearing Go caches..." &&
    go clean -cache 2>/dev/null;
    go clean -modcache 2>/dev/null;
    echo "Clearing Homebrew cache..." &&
    brew cleanup --prune=all 2>/dev/null;
    echo "Clearing Docker junk..." &&
    docker system prune -af 2>/dev/null;
    echo "Clearing Time Machine local snapshots..." &&
    sudo tmutil deletelocalsnapshots / 2>/dev/null;
    echo "Flushing DNS cache..." &&
    sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder 2>/dev/null;
    echo "Done! 🧹"
'

