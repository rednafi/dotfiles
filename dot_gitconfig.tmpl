[include]
{{- if eq .role "werk" }}
	path = ~/.gitconfig-werk
{{- else }}
	path = ~/.gitconfig-pers
{{- end }}

[includeIf "gitdir:~/canvas/pers/"]
	path = ~/.gitconfig-pers

[includeIf "gitdir:~/canvas/werk/"]
	path = ~/.gitconfig-werk
[core]
	editor = micro
[sequence]
	editor = micro
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[merge]
	tool = vimdiff
[mergetool]
	prompt = false
	keepBackup = false
